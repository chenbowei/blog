---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
}

const {
  title = 'Notebook',
  description = 'A quiet writing corner built with Astro and MDX.',
  image = '/favicon.svg',
  type = 'website',
  publishedTime
} = Astro.props;

const siteName = 'BW&BH Notebook';
const pageTitle = title === 'Notebook' ? title : `${title} | Notebook`;
const analyticsToken = import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN;
const adSenseClient = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? 'ca-pub-1321655155545412';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en" data-lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href={new URL('/rss.xml', Astro.site)} />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta property="og:site_name" content={siteName} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    {
      adSenseClient && (
        <script
          async
          src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${adSenseClient}`}
          crossorigin="anonymous"
        />
      )
    }
    {
      analyticsToken && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: analyticsToken })}
        />
      )
    }
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href="/">
          <span class="brand-copy">
            <span class="brand-name">BW&amp;BH</span>
            <span class="brand-subtitle">
              <span data-i18n="en">Notebook</span>
              <span data-i18n="zh">日记本</span>
            </span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary navigation">
          <a href="/">
            <span data-i18n="en">Home</span>
            <span data-i18n="zh">首页</span>
          </a>
          <a href="/blog/">
            <span data-i18n="en">Archive</span>
            <span data-i18n="zh">文章</span>
          </a>
          <a href="https://www.facebook.com/BobbyChen.CA/" target="_blank" rel="me noopener noreferrer">
            Facebook
          </a>
          <button class="language-toggle" type="button" aria-label="Switch language" data-language-toggle>
            <span data-i18n="en">中文</span>
            <span data-i18n="zh">English</span>
          </button>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>
          <span data-i18n="en">Keep a small record of today for tomorrow.</span>
          <span data-i18n="zh">写下今天，也给明天留一点线索。</span>
        </span>
        <a href="https://www.facebook.com/BobbyChen.CA/" target="_blank" rel="me noopener noreferrer">
          Facebook
        </a>
      </footer>
    </div>
    <script>
      const root = document.documentElement;
      const toggle = document.querySelector('[data-language-toggle]');
      const savedLanguage = localStorage.getItem('language');
      const language = savedLanguage === 'zh' ? 'zh' : 'en';

      function setLanguage(nextLanguage) {
        root.dataset.lang = nextLanguage;
        root.lang = nextLanguage === 'zh' ? 'zh-CN' : 'en';
        localStorage.setItem('language', nextLanguage);
      }

      setLanguage(language);

      toggle?.addEventListener('click', () => {
        setLanguage(root.dataset.lang === 'zh' ? 'en' : 'zh');
      });
    </script>
  </body>
</html>
